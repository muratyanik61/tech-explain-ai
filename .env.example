# Tech Explain AI - ortam degiskenleri ornegi
# Bu dosyayi ".env.local" olarak kopyalayin ve kendi anahtarinizi girin:
#   cp .env.example .env.local
#
# ".env.local" dosyasi .gitignore icinde oldugu icin GitHub'a YUKLENMEZ.

# OpenAI API anahtariniz (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-buraya-kendi-anahtarinizi-yazin

# Kullanilacak model (istege bagli, varsayilan: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
